{
  "name": "saas-microservices",
  "repository": "https://github.com/vercel/examples.git",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "dotenvx run -- turbo run build",
    "build:api": "dotenvx run -- turbo run build -F api",
    "build:dashboard": "dotenvx run -- turbo run build -F dashboard",
    "dev": "dotenvx run -- turbo run dev",
    "dev:api": "dotenvx run -- turbo run dev -F api",
    "dev:dashboard": "dotenvx run -- turbo run dev -F dashboard",
    "typecheck": "dotenvx run -- turbo run typecheck",
    "tunnel": "npx localtunnel --port 3024"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "prettier": "^3.6.2",
    "turbo": "^2.9.14"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22",
    "pnpm": "10.x"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": "6.2.1",
      "@vercel/microfrontends>path-to-regexp": "6.2.1"
    },
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma",
      "protobufjs",
      "sharp"
    ]
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.65.0",
    "@vercel/blob": "^2.3.3",
    "firebase-admin": "^13.9.0"
  }
}

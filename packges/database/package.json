{
  "name": "@repo/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "dotenvx run -- prisma generate",
    "db:migrate": "dotenvx run -- prisma migrate dev",
    "db:push": "dotenvx run -- prisma db push",
    "db:seed": "dotenvx run -- tsx prisma/seed.ts",
    "db:studio": "dotenvx run -- prisma studio",
    "build": "pnpm db:generate && tsc"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "prisma": "^7.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}


{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "tendrra-ai-v1-main-dashboard": {
     "packageName": "dashboard",
      "development": {
        "fallback": "tendrra-ai-v1-main-dashboard.vercel.app"
      }
    },
    "tendrra-ai-v1-main-api": {
      "routing": [
        {
          "paths": ["/api:path*"]
        }
      ],
      "packageName": "api",
      "development": {
        "local": 3001
      }
    }
  }
}

{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "version": "1",
  "applications": {
    "tendrra-ai-v1-main-dashboard.vercel.app": {
      "packageName": "dashboard",
      "development": {
        "fallback": "tendrra-ai-v1-main-dashboard.vercel.app"
      }
    },
    "tendrra-ai-v1-main-dashboard.vercel.app": {
      "routing": [
        {
          "paths": [
            "/api/:path*"
          ]
        }
      ],
      "packageName": "api",
      "development": {
        "task": "start",
        "local": 3024
      }
    }
  }
}
